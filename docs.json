{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Orbis",
  "description": "Documentation for Orbis — the AI relationship workspace for founders. Manage contacts, run campaigns, and automate workflows with AI agents.",
  "theme": "luma",
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg",
    "href": "https://meetorbis.com"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#6851FB",
    "light": "#ACA3F4",
    "dark": "#3D23FE"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Orbis Docs",
      "twitter:site": "@meetorbis"
    }
  },
  "thumbnails": {
    "appearance": "light",
    "fonts": {
      "family": "Inter"
    }
  },
  "integrations": {
    "intercom": {
      "appId": "vh2t8ems"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Orbis-AI-Labs/orbis2"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "icon": "pen-line",
          "href": "https://meetorbis.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "account-setup"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              {
                "group": "Contacts",
                "expanded": true,
                "pages": [
                  "contacts/overview",
                  "contacts/import",
                  "contacts/enrichment"
                ]
              },
              "companies/overview",
              "tasks",
              "boards",
              "campaigns",
              "custom-objects",
              "notes"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              {
                "group": "Google",
                "expanded": true,
                "pages": [
                  "integrations/google",
                  "integrations/add-google-account",
                  "integrations/calendar",
                  "integrations/inbox",
                  "integrations/email-health"
                ]
              },
              "integrations/linkedin"
            ]
          },
          {
            "group": "AI Features",
            "pages": [
              "ai/deep-search",
              "ai/agents",
              "ai/skills",
              "ai/tools",
              "ai/ai-fields"
            ]
          },
          {
            "group": "Workspace",
            "pages": [
              "workspace/organization",
              "workspace/team-collaboration",
              "workspace/notifications",
              "settings"
            ]
          },
          {
            "group": "Legal",
            "pages": [
              "workspace/security",
              "workspace/privacy",
              "workspace/terms"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Free Tools",
            "pages": [
              "resources/outbound-calculator",
              "resources/email-deliverability"
            ]
          },
          {
            "group": "Company Data",
            "pages": [
              "resources/sp-500",
              "resources/ftse-100",
              "resources/top-investors",
              "resources/pre-seed-investors"
            ]
          }
        ]
      }
    ]
  }
}
