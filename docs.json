{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Orbis",
  "description": "Documentation for Orbis — the AI relationship workspace for founders. Manage contacts, run campaigns, and automate workflows with AI agents.",
  "theme": "luma",
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg",
    "href": "https://meetorbis.com"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#6851FB",
    "light": "#ACA3F4",
    "dark": "#3D23FE"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Orbis Docs",
      "twitter:site": "@meetorbis"
    }
  },
  "thumbnails": {
    "appearance": "light",
    "fonts": {
      "family": "Inter"
    }
  },
  "integrations": {
    "intercom": {
      "appId": "vh2t8ems"
    }
  },
  "openapi": [
    "/api-reference/openapi.json"
  ],
  "api": {
    "baseUrl": "https://api.meetorbis.com",
    "auth": {
      "method": "bearer",
      "name": "Authorization"
    }
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Orbis-AI-Labs/orbis2"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "icon": "pen-line",
          "href": "https://meetorbis.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "account-setup"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              {
                "group": "Contacts",
                "expanded": true,
                "pages": [
                  "contacts/overview",
                  "contacts/import",
                  "contacts/enrichment"
                ]
              },
              {
                "group": "Companies",
